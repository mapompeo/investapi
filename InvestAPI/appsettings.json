{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=investapi.db"
  },
  "JwtSettings": {
    "SecretKey": "SET_THIS_IN_ENVIRONMENT_MINIMUM_32_BYTES",
    "Issuer": "InvestAPI",
    "Audience": "InvestAPI-Users",
    "ExpirationInDays": 7
  },
  "QuoteSettings": {
    "CacheMinutes": 5,
    "BrapiBaseUrl": "https://brapi.dev",
    "BrapiToken": "",
    "CoinGeckoBaseUrl": "https://api.coingecko.com",
    "CoinGeckoVsCurrency": "usd",
    "CoinGeckoTickerToId": {
      "BTC": "bitcoin",
      "ETH": "ethereum",
      "SOL": "solana",
      "XRP": "ripple",
      "ADA": "cardano",
      "DOGE": "dogecoin"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  },
  "RateLimiting": {
    "PermitLimit": 120,
    "WindowMinutes": 1,
    "QueueLimit": 0
